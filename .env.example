# --- STDIO / local desktop usage (src/index.ts) ---
# Raindrop.io API Access Token (REQUIRED for local/STDIO usage only)
# Create one at https://app.raindrop.io/settings/integrations
RAINDROP_ACCESS_TOKEN=YOUR_RAINDROP_ACCESS_TOKEN

# --- HTTP / hosted usage (src/server.ts) ---
# Do NOT set RAINDROP_ACCESS_TOKEN for a hosted/multi-tenant deployment.
# Each connecting client must supply its own token via the
# 'Authorization: Bearer <token>' header on its MCP requests instead.

# Public base URL the service is reachable at once deployed (used to derive
# the OAuth redirect URI and the DNS-rebinding-protection allowlist).
PUBLIC_URL=https://your-deployment.example.com

# Comma-separated hostnames allowed to reach this server (DNS rebinding protection).
ALLOWED_HOSTS=your-deployment.example.com

# Optional: only needed if using the /auth/raindrop OAuth convenience endpoints.
RAINDROP_CLIENT_ID=
RAINDROP_CLIENT_SECRET=
RAINDROP_REDIRECT_URI=

# Port the HTTP server listens on (most hosting platforms inject PORT).
PORT=3002

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
